      *>================================================================*
      *> CLMGEN.cob — Test data generator for claims system
      *> Compile: cobc -x -free -I copybooks CLMGEN.cob
      *> Creates:
      *>   data/POLICIES.DAT    (5 policy records)
      *>   data/PROVIDERS.DAT   (48 fee schedule records)
      *>   data/CLAIMS.DAT      (10 claims, ~40 records total)
      *>================================================================*
       IDENTIFICATION DIVISION.
       PROGRAM-ID. CLMGEN.

       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT POLICY-FILE
               ASSIGN TO 'data/POLICIES.DAT'
               ORGANIZATION IS SEQUENTIAL
               FILE STATUS IS WS-POL-STATUS.
           SELECT PROVIDER-FILE
               ASSIGN TO 'data/PROVIDERS.DAT'
               ORGANIZATION IS SEQUENTIAL
               FILE STATUS IS WS-PROV-STATUS.
           SELECT CLAIMS-FILE
               ASSIGN TO 'data/CLAIMS.DAT'
               ORGANIZATION IS SEQUENTIAL
               FILE STATUS IS WS-CLM-STATUS.

       DATA DIVISION.
       FILE SECTION.
       FD  POLICY-FILE.
       COPY POLREC.

       FD  PROVIDER-FILE.
       COPY FEESCHED.

       FD  CLAIMS-FILE.
       COPY CLAIMREC.

       WORKING-STORAGE SECTION.
       01  WS-POL-STATUS             PIC XX.
       01  WS-PROV-STATUS            PIC XX.
       01  WS-CLM-STATUS             PIC XX.
       01  WS-POL-COUNT              PIC 99 VALUE 0.
       01  WS-PROV-COUNT             PIC 999 VALUE 0.
       01  WS-CLM-COUNT              PIC 999 VALUE 0.
       01  WS-CHECK-NUM              PIC 9(8) VALUE 10000001.

      *> Working fields for building COMP-3 values
       01  WS-WORK-AMT               PIC S9(7)V99 VALUE 0.
       01  WS-WORK-RATE              PIC S9(5)V99 VALUE 0.
       01  WS-WORK-COPAY             PIC S9(3)V99 VALUE 0.
       01  WS-WORK-DEDUCT            PIC S9(5)V99 VALUE 0.
       01  WS-WORK-OOP               PIC S9(5)V99 VALUE 0.
       01  WS-IDX                    PIC 99 VALUE 0.

       PROCEDURE DIVISION.
       MAIN-PARA.
           PERFORM GENERATE-POLICIES
           PERFORM GENERATE-PROVIDERS
           PERFORM GENERATE-CLAIMS
           DISPLAY 'CLMGEN COMPLETE'
           DISPLAY '  POLICIES:  ' WS-POL-COUNT
           DISPLAY '  FEE SCHED: ' WS-PROV-COUNT
           DISPLAY '  CLAIM RECS:' WS-CLM-COUNT
           STOP RUN.

